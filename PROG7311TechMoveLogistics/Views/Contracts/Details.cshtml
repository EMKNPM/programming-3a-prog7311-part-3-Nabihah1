@model TechMoveLogisticsAPI.DTOs.ContractDto
@using TechMoveLogisticsAPI.DTOs

@{
    ViewData["Title"] = "Details";
}

<h1 class="row justify-content-center mb-3"> CONTRACT DETAILS</h1>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm p-4 h-100">

            <!-- Header -->
            <div class="d-flex justify-content-between align-items-start">
                <h4 class="fw-bold mb-1">
                    Contract #@Model.ContractId
                </h4>

                <span class="badge
                    @(Model.ContractStatus == ContractStatusDto.Active ? "bg-success" :
                        Model.ContractStatus == ContractStatusDto.Draft ? "bg-warning text-dark" :
                        Model.ContractStatus == ContractStatusDto.Expired ? "bg-secondary" :
                        Model.ContractStatus == ContractStatusDto.OnHold ? "bg-dark" :
                        "bg-secondary")">

                    @Model.ContractStatus
                </span>
            </div>

            <hr />

            <p class="mb-2">
                <strong>Start Date:</strong>@Model.ContractStartDate
            </p>

            <p class="mb-2">
                <strong>End Date:</strong>@Model.ContractEndDate
            </p>


            <p class="mb-2">
                <strong>Service Level:</strong>@Model.ContractServiceLevel
            </p>

            <p class="mb-2">
                <strong>Client ID:</strong>@Model.ClientId
            </p>

            <br />




            <!-- FILE SECTION -->
            <h4>Signed Agreement</h4>
            <hr />

            @if (Model.Documents != null && Model.Documents.Any())
            {
                <ul>
                    @foreach (var doc in Model.Documents)
                    {
                        <li>
                            @doc.FileName <br />

                            <a href="@doc.FileUrl" target="_blank" class="btn btn-sm btn-success">
                                View / Download PDF
                            </a>

                            <small class="text-muted">
                                (Uploaded: @doc.UploadedDate)
                            </small>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-danger">No signed document uploaded.</p>
            }

            <hr />



            <!-- Actions -->
            <div class="mt-3">
                <a asp-action="Edit" asp-route-id="@Model?.ContractId" class="btn btn-primary">
                    Edit
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    Back to List
                </a>
            </div>


        </div>
    </div>
</div>
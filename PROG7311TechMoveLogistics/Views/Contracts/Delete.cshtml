@model PROG7311TechMoveLogistics.Models.Contract

@{
    ViewData["Title"] = "Delete";
}

<h1 class="mb-3">DELETE CONTRACTS</h1>

<h5 class="mb-4 text-dange`">Are you sure you want to delete this request?</h5>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm p-4 border-danger">

            <!-- Header -->
            <div class="d-flex justify-content-between align-items-start">
                <h4 class="fw-bold mb-1 text-danger">
                    Contract #@Model.ContractId
                </h4>

                <span class="badge
                    @(Model.ContractStatus == ContractStatus.Active ? "bg-success" :
                                                                                                Model.ContractStatus == ContractStatus.Expired ? "bg-danger" :
                                                                                                Model.ContractStatus == ContractStatus.OnHold ? "bg-warning text-dark" :
                                                                                                "bg-secondary")">
                    @Model.ContractStatus
                </span>
            </div>

            <hr />


             
    
            <!-- Description -->
            <p class="mb-2">
                <strong>Start Date:</strong>@Model.ContractStartDate
            </p>

            <!-- Costs -->
            <p class="mb-2">
                <strong>Ebd Date:</strong> @Model.ContractEndDate
            </p>

            <p class="mb-2">
                <strong>Status:</strong> @Model.ContractStatus
            </p>

            <!-- Contract -->
            <p class="mb-3">
                <strong>Service Level:</strong> @Model.ContractServiceLevel
            </p>

            <p class="mb-3">
                <strong>Client ID:</strong> @Model.ClientId
            </p>


         
 


        <!-- Warning -->
        <div class="alert alert-danger mt-3">
            This action cannot be undone.
        </div>

        <!-- Actions -->
        <form asp-action="Delete" class="mt-3">
            <input type="hidden" asp-for="ContractId" />

            <button type="submit" class="btn btn-danger">
                Confirm Delete
            </button>

            <a asp-action="Index" class="btn btn-outline-secondary ms-2">
                Cancel
            </a>
        </form>

    </div>
</div>
</div>


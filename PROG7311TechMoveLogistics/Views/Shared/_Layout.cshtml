<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PROG7311</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PROG7311_M__TechMoveLogistics.styles.css" asp-append-version="true" />
</head>
<body>
 
    <!-- adding a sidebar with a main page layout -->

    <div class="d-flex">

        <!-- sidebar -->
        <div class="sidebar p-3">
            <h4 class="text-white"> TechMove Logistics </h4>
            <hr class="text-white" />

            <ul class="nav nav-pills flex-column">

                <!-- Dashbooard -->
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Index"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "text-white")">
                        Dashboard
                        <!-- route data makes the tab highlight, so u know which screen u on -->
                    </a>
                </li>

                <!-- Management section  -->
                <li class="mt-3 text-white-50">MANAGEMENT</li>

                <li class="nav-item">
                    <a asp-controller="Clients" asp-action="Index"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Clients" ? "active" : "text-white")">
                        Clients
                    </a>
                </li>

                <li class="nav-item">
                    <a asp-controller="Contracts" asp-action="Index"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contracts" ? "active" : "text-white")">
                        Contracts
                    </a>
                </li>

                <!-- Operations section -->
                <li class="mt-3 text-white-50">OPERATIONS</li>

                <li class="nav-item">
                    <a asp-controller="ServiceRequests" asp-action="Index"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ServiceRequests" ? "active" : "text-white")">
                        Service Requests
                    </a>
                </li>
            </ul>
        </div>

        <!-- Main content of screen (will change as u switching between pages)-->
        <div class="content p-4">
            @RenderBody()
        </div>

    </div>


  
 




    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>




</html>

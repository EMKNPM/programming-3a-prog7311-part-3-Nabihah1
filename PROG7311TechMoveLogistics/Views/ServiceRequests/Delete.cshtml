@model PROG7311TechMoveLogistics.Models.ServiceRequest
@using PROG7311TechMoveLogistics.Models

@{
    ViewData["Title"] = "Delete";
}

<h1 class="mb-3">DELETE SERVICE REQUEST</h1>

<h5 class="mb-4 text-dange`">Are you sure you want to delete this request?</h5>

<div class ="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm p-4 border-danger">

            <!-- Header -->
            <div class="d-flex justify-content-between align-items-start">
                <h4 class="fw-bold mb-1 text-danger">
                    Request #@Model.ServiceRequestId
                </h4>

                <span class="badge
                    @(Model.SrStatus == ServiceRequestStatus.Completed ? "bg-success" :
                                                                  Model.SrStatus == ServiceRequestStatus.Pending ? "bg-warning text-dark" :
                                                                  Model.SrStatus == ServiceRequestStatus.Cancelled ? "bg-danger" :
                                                                  "bg-secondary")">
                    @Model.SrStatus
                </span>
            </div>

            <hr />

            <!-- Description -->
            <p class="mb-2">
                <strong>Description:</strong>@Model.SrDescription
            </p>

            <!-- Costs -->
            <p class="mb-2">
                <strong>Foreign:</strong> $@Model.CostForeign.ToString("F2")
            </p>

            <p class="mb-2">
                <strong>ZAR:</strong> R @Model.CostZAR.ToString("F2")
            </p>

            <!-- Contract -->
            <p class="mb-3">
                <strong>Contract:</strong> #@Model.Contract?.ContractId
            </p>

            <!-- Warning -->
            <div class="alert alert-danger mt-3">
                This action cannot be undone.
            </div>

            <!-- Actions -->
            <form asp-action="Delete" class="mt-3">
                <input type="hidden" asp-for="ServiceRequestId" />

                <button type="submit" class="btn btn-danger">
                    Confirm Delete
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary ms-2">
                    Cancel
                </a>
            </form>

        </div>
    </div>
    </div>


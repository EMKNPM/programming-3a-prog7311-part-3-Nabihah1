@model PROG7311TechMoveLogistics.Models.ServiceRequest

@{
    ViewData["Title"] = "Edit";
}

<h2 class="mb-4">Edit Service Request</h2>

<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="card shadow-sm p-4">

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["ErrorMessage"]
                </div>
            }

         
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="ServiceRequestId" />
                <div class="form-group">
                    <label asp-for="SrDescription" class="control-label fw-semibold">Description</label>
                    <input asp-for="SrDescription" class="form-control" />
                    <span asp-validation-for="SrDescription" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="CostForeign" class="control-label fw-semibold"> International Curreny</label>
                    <input asp-for="CostForeign" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="CostForeign" class="text-danger"></span>
                </div>

                @*    <div class="form-group">
                <label asp-for="CostZAR" class="control-label fw-semibold"></label>
                <input asp-for="CostZAR" class="form-control" />
                <span asp-validation-for="CostZAR" class="text-danger"></span>
            </div> *@

                <div class="form-group">
                    <label asp-for="SrStatus" class="control-label fw-semibold">Current Status</label>
                    <select asp-for="SrStatus" class="form-control" asp-items="Html.GetEnumSelectList<ServiceRequestStatus>()"></select>
                    <span asp-validation-for="SrStatus" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ContractId" class="control-label fw-semibold"> Contract ID</label>
                    <select asp-for="ContractId" class="form-control" asp-items="ViewBag.ContractId"></select>
                    <span asp-validation-for="ContractId" class="text-danger"></span>
                </div>


         
                <!-- Buttons -->
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">Save Request</button>
                </div>
            </form>
        </div>
    </div>

</div>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

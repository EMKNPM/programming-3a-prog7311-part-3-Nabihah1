@model PROG7311TechMoveLogistics.Models.Client

@{
    ViewData["Title"] = "Delete";
}
   

    <h1 class="mb-3">DELETE CLIENT</h1>

    <h5 class="mb-4 text-dange`">Are you sure you want to delete this request?</h5>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm p-4 border-danger">

                <!-- Header -->
                <div class="d-flex justify-content-between align-items-start">
                    <h4 class="fw-bold mb-1 text-danger">
                        Client #@Model.ClientId
                    </h4>

                </div>


                <hr />

    
            <p class="mb-2">
                <strong>Name:</strong>@Model.ClientName
            </p>

            <!-- Costs -->
            <p class="mb-2">
                <strong>Contact Details:</strong> @Model.ContactDetails
            </p>

            <p class="mb-2">
                <strong>Region:</strong>@Model.Region
            </p>

       

        <!-- Warning -->
        <div class="alert alert-danger mt-3">
            This action cannot be undone.
        </div>

        <!-- Actions -->
        <form asp-action="Delete" class="mt-3">
            <input type="hidden" asp-for="ClientId" />

            <button type="submit" class="btn btn-danger">
                Confirm Delete
            </button>

            <a asp-action="Index" class="btn btn-outline-secondary ms-2">
                Cancel
            </a>
        </form>

    </div>
</div>
</div>


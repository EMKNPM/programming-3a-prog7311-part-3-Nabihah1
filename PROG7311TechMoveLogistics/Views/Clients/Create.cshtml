@model PROG7311TechMoveLogistics.Models.Client

@{
    ViewData["Title"] = "Create";
}

<h2 class="mb-4">Add New Client</h2>

<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="card shadow-sm p-4">

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["ErrorMessage"]
                </div>
            }


            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- Client Name -->
                <div class="mb-3">
                    <label asp-for="ClientName" class="form-label fw-semibold">Name</label>
                    <input asp-for="ClientName" class="form-control" placeholder="Enter client name..." />
                    <span asp-validation-for="ClientName" class="text-danger"></span>
                </div>

                <!-- Contact -->
                <div class="mb-3">
                    <label asp-for="ContactDetails" class="form-label fw-semibold"> Contact Details</label>
                    <input asp-for="ContactDetails" class="form-control" placeholder="Email or phone number..." />
                    <span asp-validation-for="ContactDetails" class="text-danger"></span>
                </div>

                <!-- Region -->
                <div class="mb-3">
                    <label asp-for="Region" class="form-label fw-semibold">Region</label>
                    <input asp-for="Region" class="form-control" placeholder="e.g. Toronto, Johannesburg..." />
                    <span asp-validation-for="Region" class="text-danger"></span>
                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">Save Client</button>
                </div>

            </form>

        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
